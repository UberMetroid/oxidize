# ==============================================================================
# Docker Build Context Optimization
# Only the source code and build files are needed inside the container.
# ==============================================================================

# Git
.git
.gitignore

# Build artifacts
target/
dist/

# IDE
.vscode/
.idea/
*.swp

# Environment files (secrets should never be in build context)
.env
.env.local
.env.*.local

# Documentation (not needed in production)
*.md
!README.md

# UI source (built separately with wasm-pack/trunk)
oxidize-ui/src/
oxidize-ui/index.html
oxidize-ui/styles/
oxidize-ui/tests/

# Tests
**/tests/
**/benches/
!oxidize-engine/benches/

# OS artifacts
.DS_Store
Thumbs.db

# Logs
*.log
